{
  "expo": {
    "name": "SupFile Mobile",
    "slug": "supfile-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "extra": {
      "apiUrl": "http://192.168.1.16:3000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.supfile.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Cette application a besoin d'accéder à vos photos pour vous permettre de changer votre photo de profil."
      }
    },
    "android": {
      "package": "com.supfile.mobile",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-audio",
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "Cette application a besoin d'accéder à vos photos pour vous permettre de changer votre photo de profil."
        }
      ]
    ]
  }
}
